        },
        {
          "name": "Reject Friend Request",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": "{{base_url}}/api/v1/friendships/{{friendship_id}}"
          }
        }
      ]
    },
