            ],
            "url": "{{base_url}}/api/v1/trips/{{trip_id}}/members/{{user_id}}"
          }
        }
      ]
    },
    {
      "name": "Trip Itineraries",
      "item": [
        {
          "name": "Create Itinerary",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Cafe stop\",\n  \"scheduled_for\": \"2026-04-10 12:00:00\",\n  \"notes\": \"Near the beach\"\n}"
            },
            "url": "{{base_url}}/api/v1/trips/{{trip_id}}/itineraries"
          }
        }
      ]
    },
    {
      "name": "Trip Expenses",
      "item": [
        {
          "name": "Create Expense",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Taxi\",\n  \"amount\": 32.5,\n  \"currency\": \"USD\",\n  \"paid_by_user_id\": 1,\n  \"split_user_ids\": [1,2],\n  \"incurred_on\": \"2026-04-10\",\n  \"notes\": \"Airport transfer\"\n}"
            },
            "url": "{{base_url}}/api/v1/trips/{{trip_id}}/expenses"
          }
        },
        {
          "name": "Update Expense",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Taxi Updated\",\n  \"amount\": 35,\n  \"currency\": \"USD\",\n  \"paid_by_user_id\": 1,\n  \"split_user_ids\": [1,2]\n}"
            },
            "url": "{{base_url}}/api/v1/trips/{{trip_id}}/expenses/{{trip_expense_id}}"
          }
        }
      ]
    },
    {
      "name": "Friendships",
      "item": [
